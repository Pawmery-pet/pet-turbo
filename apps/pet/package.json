{
	"name": "pet",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "pnpm db:generate && tsup",
		"start": "node dist/index.js",
		"db:generate": "prisma generate --schema=src/lib/prisma/schema.prisma",
		"db:push": "prisma db push --schema=src/lib/prisma/schema.prisma",
		"db:studio": "prisma studio --schema=src/lib/prisma/schema.prisma",
		"lint": "echo 'No linting configured'",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"@prisma/client": "^5.22.0",
		"cors": "^2.8.5",
		"dotenv": "^16.4.7",
		"express": "^4.21.2",
		"helmet": "^8.0.0",
		"swagger-jsdoc": "^6.2.8",
		"swagger-ui-express": "^5.0.1"
	},
	"devDependencies": {
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.0",
		"@types/node": "^22.10.2",
		"@types/swagger-jsdoc": "^6.0.4",
		"@types/swagger-ui-express": "^4.1.8",
		"prisma": "^5.22.0",
		"tsup": "^8.5.0",
		"tsx": "^4.19.2",
		"typescript": "^5.8.3"
	}
}