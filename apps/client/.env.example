# AUTH (Better-Auth)
# Generate a random 32+ char secret: https://generate-secret.vercel.app/32
BETTER_AUTH_SECRET=
# Public base URL of this Next.js app (prod or local)
BETTER_AUTH_URL=http://localhost:3000
# Comma-separated origins allowed to call auth endpoints (optional)
BETTER_AUTH_TRUSTED_ORIGINS=

# OIDC Provider (Authentik) - PAWMERY_PET_IDP
# Copy these from Authentik Provider/Application settings
PAWMERY_PET_IDP_CLIENT_ID=
PAWMERY_PET_IDP_CLIENT_SECRET=
# OpenID Configuration URL (well-known); example below
PAWMERY_PET_IDP_DISCOVERY_URL=http://localhost:9000/application/o/pet-client/.well-known/openid-configuration
