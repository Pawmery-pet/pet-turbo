# Server Configuration (AppConfigService picks: config.yaml -> .env -> defaults)
HOST=0.0.0.0
PORT=3020
ENVIRONMENT=development

# Database (if adding Prisma later)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/golden-retriever

# Authentik API (User data source)
# Example: https://auth.pawmery.pet
AUTHENTIK_BASE_URL=
# Service token with read access to core users
AUTHENTIK_API_TOKEN=
# Default: Bearer
AUTHENTIK_API_TOKEN_TYPE=Bearer
# Request timeout in milliseconds
AUTHENTIK_TIMEOUT_MS=5000
# Max retries after initial attempt
AUTHENTIK_RETRY_COUNT=2
# Retry backoff base in milliseconds
AUTHENTIK_RETRY_DELAY_MS=250

# CORS (if adding CORS later)
# CORS_ORIGIN=http://localhost:3000
