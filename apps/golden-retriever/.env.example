# Server Configuration (AppConfigService picks: config.yaml -> .env -> defaults)
HOST=0.0.0.0
PORT=3020
ENVIRONMENT=development

# Database (if adding Prisma later)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/golden-retriever

# CORS (if adding CORS later)
# CORS_ORIGIN=http://localhost:3000

# S3 Storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=pawmery-dev
